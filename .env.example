# OpenAI auto-registration system - example environment configuration
# Copy this file to .env and fill in the values you need.

# ── Web UI listen address ───────────────────────────────────
# Listen host (default: 0.0.0.0)
# APP_HOST=0.0.0.0

# Listen port (default: 8000)
# APP_PORT=8000

# Web UI access password (default: admin123, strongly recommended to change)
# APP_ACCESS_PASSWORD=your_secret_password

# ── Database ────────────────────────────────────────────────
# Local SQLite (default, no configuration required)
# APP_DATABASE_URL=data/database.db

# Remote PostgreSQL (takes precedence)
# APP_DATABASE_URL=postgresql://user:password@host:5432/dbname
